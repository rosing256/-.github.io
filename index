<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>你的"附近"人格查询器 | NCT测试</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#f7f7fc;--card:#ffffff;--card2:#f0f0f8;--accent:#6c5ce7;--accent2:#5a4bd1;--green:#00b894;--pink:#e84393;--orange:#e17055;--text:#2d3436;--dim:#636e72;--glow:rgba(108,92,231,.18);--shadow:0 2px 12px rgba(0,0,0,.06);--shadow-lg:0 8px 30px rgba(0,0,0,.1)}
body{font-family:'Noto Sans SC','PingFang SC','Microsoft YaHei',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;-webkit-font-smoothing:antialiased}

/* BG */
.bg{position:fixed;inset:0;z-index:0;pointer-events:none}
.bg .o{position:absolute;border-radius:50%;filter:blur(100px);opacity:.15;animation:drift 22s infinite ease-in-out}
.bg .o:nth-child(1){width:420px;height:420px;background:#a29bfe;top:-120px;left:-80px}
.bg .o:nth-child(2){width:360px;height:360px;background:#55efc4;bottom:-100px;right:-60px;animation-delay:-8s}
.bg .o:nth-child(3){width:280px;height:280px;background:#fd79a8;top:40%;left:60%;animation-delay:-15s}
@keyframes drift{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(40px,-30px) scale(1.08)}66%{transform:translate(-30px,30px) scale(.94)}}

.wrap{position:relative;z-index:1;max-width:600px;margin:0 auto;padding:20px;min-height:100vh;display:flex;flex-direction:column}

/* Progress */
.top-bar{margin-bottom:24px}
.top-row{display:flex;justify-content:space-between;font-size:12px;color:var(--dim);margin-bottom:6px;font-weight:500}
.prog{width:100%;height:4px;background:rgba(0,0,0,.06);border-radius:2px;overflow:hidden}
.prog .bar{height:100%;background:linear-gradient(90deg,var(--accent),var(--green));border-radius:2px;transition:width .5s ease}

/* Stage tag */
.stag{display:inline-block;font-size:11px;padding:4px 14px;border-radius:20px;font-weight:600;margin-bottom:12px}
.stag.s1{background:rgba(108,92,231,.08);color:var(--accent)}
.stag.s2{background:rgba(0,184,148,.08);color:var(--green)}
.stag.s3{background:rgba(232,67,147,.08);color:var(--pink)}
.stag.s4{background:rgba(225,112,85,.08);color:var(--orange)}

/* Question area */
.q-area{flex:1;display:flex;flex-direction:column;justify-content:center;animation:fadeUp .4s ease}
.q-text{font-size:18px;font-weight:700;line-height:1.8;margin-bottom:8px;color:#1a1a2e}
.q-num{color:var(--accent);margin-right:4px}
.q-hint{font-size:13px;color:var(--dim);margin-bottom:14px;line-height:1.6}

/* Options */
.opts{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.obtn{background:var(--card);border:2px solid rgba(0,0,0,.06);border-radius:14px;padding:14px 16px;font-size:15px;line-height:1.6;color:var(--text);cursor:pointer;transition:all .2s;text-align:left;font-family:inherit;display:flex;align-items:flex-start;gap:10px;box-shadow:var(--shadow)}
.obtn:hover{border-color:rgba(108,92,231,.25);background:#fafafe;box-shadow:0 4px 16px rgba(0,0,0,.08)}
.obtn.sel{border-color:var(--accent);box-shadow:0 0 0 3px var(--glow);background:rgba(108,92,231,.04)}
.obtn .lt{flex-shrink:0;width:26px;height:26px;line-height:26px;text-align:center;border-radius:50%;font-size:12px;font-weight:700;background:rgba(108,92,231,.1);color:var(--accent);transition:all .2s}
.obtn.sel .lt{background:var(--accent);color:#fff}
.obtn.ck .lt{border-radius:6px;font-size:13px;border:2px solid rgba(0,0,0,.12);background:transparent;color:transparent;width:24px;height:24px;line-height:18px}
.obtn.ck.on .lt{border-color:var(--green);background:var(--green);color:#fff}
.obtn.ck.on{border-color:var(--green);box-shadow:0 0 0 3px rgba(0,184,148,.15)}

/* Rating */
.rrow{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.rrow .rl{flex:1;font-size:14px;line-height:1.6;color:#2d3436}
.rrow .rv{display:flex;gap:6px;flex-shrink:0}
.rbtn{width:36px;height:36px;border-radius:10px;border:2px solid rgba(0,0,0,.08);background:var(--card);color:var(--dim);font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;font-family:inherit}
.rbtn:hover{border-color:rgba(108,92,231,.3)}
.rbtn.on{border-color:var(--accent);background:rgba(108,92,231,.08);color:var(--accent);font-weight:800}

/* Text input */
.tinput{width:100%;background:var(--card);border:2px solid rgba(0,0,0,.08);border-radius:14px;padding:14px 16px;font-size:15px;color:var(--text);font-family:inherit;resize:vertical;min-height:90px;outline:none;transition:border-color .2s;box-shadow:var(--shadow)}
.tinput:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--glow)}
.tinput::placeholder{color:#b2bec3}

/* Nav */
.nav{display:flex;justify-content:space-between;align-items:center;padding:20px 0}
.nbtn{padding:11px 26px;border-radius:50px;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;font-family:inherit;border:none}
.nbtn.prev{background:var(--card);border:1px solid rgba(0,0,0,.1);color:var(--dim);box-shadow:var(--shadow)}
.nbtn.prev:hover{border-color:rgba(0,0,0,.2);color:var(--text)}
.nbtn.next{background:linear-gradient(135deg,var(--accent),#8b5cf6);color:#fff;box-shadow:0 2px 12px var(--glow)}
.nbtn.next:hover{box-shadow:0 6px 24px var(--glow);transform:translateY(-1px)}
.nbtn.next:disabled{opacity:.35;cursor:not-allowed;transform:none;box-shadow:none}
.nbtn.submit{background:linear-gradient(135deg,var(--accent),var(--green));color:#fff;padding:13px 34px;font-size:15px;box-shadow:0 2px 16px var(--glow)}

/* Intro */
.intro{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;text-align:center}
.intro .logo{font-size:64px;margin-bottom:12px}
.intro h1{font-size:30px;font-weight:900;background:linear-gradient(135deg,var(--accent),#00b894);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:8px}
.intro .sub{font-size:13px;color:var(--dim);letter-spacing:4px;text-transform:uppercase;margin-bottom:24px;font-weight:500}
.intro .desc{font-size:14px;color:#636e72;line-height:2;max-width:460px;margin-bottom:30px}
.dims{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;max-width:420px;margin-bottom:30px}
.dcard{background:var(--card);border-radius:12px;padding:14px;text-align:left;border:1px solid rgba(0,0,0,.05);box-shadow:var(--shadow)}
.dcard .dl{font-size:11px;color:var(--dim);margin-bottom:4px}
.dcard .dv{font-size:13px;font-weight:700}
.dcard .dv .vs{color:#b2bec3;font-weight:400;margin:0 4px}
.start-btn{background:linear-gradient(135deg,var(--accent),#8b5cf6);color:#fff;border:none;padding:15px 44px;border-radius:50px;font-size:17px;font-weight:800;cursor:pointer;transition:all .3s;box-shadow:0 4px 24px var(--glow);font-family:inherit}
.start-btn:hover{transform:translateY(-2px);box-shadow:0 8px 32px var(--glow)}

/* Result */
.result{display:none;flex-direction:column;align-items:center;min-height:100vh;padding-top:30px;text-align:center;animation:fadeUp .6s ease}
.result.show{display:flex}
.result .illust{margin-bottom:20px}
.result .rcode{font-size:52px;font-weight:900;letter-spacing:6px;background:linear-gradient(135deg,var(--accent),#00b894);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:8px;animation:fadeUp .8s ease}
.result .rname{font-size:22px;font-weight:800;color:#1a1a2e;margin-bottom:14px;animation:fadeUp .8s ease .1s both}
.result .rmotto{font-size:15px;color:var(--accent);font-style:italic;margin-bottom:22px;font-weight:500;animation:fadeUp .8s ease .15s both}
.result .rdesc{font-size:14px;line-height:2.1;color:#636e72;max-width:440px;margin-bottom:28px;animation:fadeUp .8s ease .2s both}
.result .rdims{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;max-width:420px;margin-bottom:30px;animation:fadeUp .8s ease .25s both}
.rdim{background:var(--card);border-radius:12px;padding:14px;text-align:center;border:1px solid rgba(0,0,0,.05);box-shadow:var(--shadow)}
.rdim .rl{font-size:11px;color:var(--dim);margin-bottom:3px}
.rdim .rv{font-size:16px;font-weight:800}
.rdim .rs{font-size:11px;color:#b2bec3;margin-top:3px}
.rbtn2{background:var(--card);border:2px solid rgba(0,0,0,.08);color:var(--dim);padding:11px 30px;border-radius:50px;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit;margin-bottom:40px;box-shadow:var(--shadow);animation:fadeUp .8s ease .3s both}
.rbtn2:hover{border-color:var(--accent);color:var(--accent)}

/* Admin */
.admin-btn{position:fixed;top:12px;right:12px;z-index:10;background:var(--card);border:1px solid rgba(0,0,0,.08);border-radius:8px;padding:7px 14px;font-size:11px;color:var(--dim);cursor:pointer;font-family:inherit;transition:all .2s;box-shadow:var(--shadow)}
.admin-btn:hover{border-color:var(--accent);color:var(--accent)}
.admin{min-height:100vh;padding-top:10px}
.admin h2{font-size:20px;font-weight:800;color:#1a1a2e;margin-bottom:4px}
.admin .sub{font-size:13px;color:var(--dim);margin-bottom:20px}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px}
.stat-card{background:var(--card);border-radius:12px;padding:16px;border:1px solid rgba(0,0,0,.05);box-shadow:var(--shadow)}
.stat-card .sl{font-size:11px;color:var(--dim);margin-bottom:3px}
.stat-card .sv{font-size:24px;font-weight:800}
.chart-row{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap}
.chart-box{background:var(--card);border-radius:14px;padding:18px;flex:1;min-width:260px;border:1px solid rgba(0,0,0,.05);box-shadow:var(--shadow)}
.chart-box h3{font-size:13px;font-weight:700;margin-bottom:10px;color:#1a1a2e}
.chart-box svg{width:100%}
.tbl-wrap{overflow-x:auto;margin-bottom:20px}
.tbl-wrap table{width:100%;border-collapse:collapse;font-size:12px}
.tbl-wrap th{background:var(--card2);padding:8px 6px;text-align:left;font-weight:700;white-space:nowrap;border-bottom:2px solid rgba(0,0,0,.08);color:#2d3436}
.tbl-wrap td{padding:7px;border-bottom:1px solid rgba(0,0,0,.04);white-space:nowrap;max-width:200px;overflow:hidden;text-overflow:ellipsis;color:#2d3436}
.exp-row{display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap}
.exp-btn{background:var(--card);border:1px solid rgba(0,0,0,.08);border-radius:10px;padding:10px 18px;font-size:13px;color:var(--text);cursor:pointer;font-family:inherit;transition:all .2s;box-shadow:var(--shadow);font-weight:500}
.exp-btn:hover{border-color:var(--accent);color:var(--accent)}
.q-stat{background:var(--card);border-radius:14px;padding:18px;margin-bottom:14px;border:1px solid rgba(0,0,0,.05);box-shadow:var(--shadow);animation:fadeUp .3s ease}
.q-stat .qs-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px}
.q-stat .qs-num{font-size:11px;color:var(--accent);font-weight:700}
.q-stat .qs-type{font-size:10px;color:var(--dim);background:rgba(0,0,0,.04);padding:3px 10px;border-radius:10px;font-weight:500}
.q-stat .qs-text{font-size:14px;font-weight:700;line-height:1.6;margin-bottom:12px;color:#1a1a2e}
.q-stat .qs-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.q-stat .qs-lbl{flex-shrink:0;width:24px;height:24px;line-height:24px;text-align:center;border-radius:50%;font-size:11px;font-weight:700;background:rgba(108,92,231,.08);color:var(--accent)}
.q-stat .qs-bar-wrap{flex:1;height:22px;background:rgba(0,0,0,.03);border-radius:6px;overflow:hidden;position:relative}
.q-stat .qs-bar{height:100%;border-radius:6px;transition:width .5s ease;min-width:2px}
.q-stat .qs-bar-text{position:absolute;right:8px;top:50%;transform:translateY(-50%);font-size:11px;color:#2d3436;white-space:nowrap;font-weight:600}
.q-stat .qs-opt{font-size:12px;line-height:1.5;color:var(--dim);margin-bottom:6px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
.q-stat .qs-avg{font-size:12px;color:var(--accent);font-weight:700}
.section-title{font-size:16px;font-weight:800;margin:28px 0 14px;padding-bottom:8px;border-bottom:2px solid rgba(0,0,0,.06);color:#1a1a2e}

/* Filter end */
.fend{display:none;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;text-align:center}
.fend.show{display:flex}
.fend .flogo{font-size:48px;margin-bottom:16px}
.fend .fmsg{font-size:16px;color:var(--dim);margin-bottom:10px;line-height:1.8}

@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:480px){.intro h1{font-size:24px}.result .rcode{font-size:38px}.rrow{flex-direction:column;align-items:flex-start}.rrow .rv{align-self:flex-start}}
</style>
</head>
<body>
<div class="bg"><div class="o"></div><div class="o"></div><div class="o"></div></div>
<div class="wrap" id="app"></div>
<script>
const $=s=>document.querySelector(s);
const app=document.getElementById('app');

// ===== TYPES & ILLUSTRATIONS =====
const TYPES={
'Guardian':{name:'在地守望者',en:'The Guardian',motto:'附近没我不行。',desc:'你对附近有真实的情感投入，不只是习惯性地居住，而是主动地生活。你知道常去的小店老板最近是否生意不好，会注意到哪条巷子多了一面涂鸦墙，也会在邻居需要时伸出手。这种关注不是刻意经营，而是一种自然的生活姿态。在附近感普遍稀薄的城市里，你是少数仍在维系某种真实社区性的人。'},
'Builder':{name:'社区营造者',en:'The Builder',motto:'附近，是我亲手搭建的。',desc:'你不只在乎附近，你在主动建造它。你会组织或参与社区活动，在线下空间中搭建连接，把"附近"当成一个需要维护和耕耘的公共品。你对陌生人有足够的开放度，对公共事务有投入感，相信人与人之间的信任是可以被培养的。你是城市社会资本里罕见的生产者，而不只是消费者。'},
'Passerby':{name:'氛围栖居者',en:'The Passerby',motto:'我消费的是氛围，不是社交。',desc:'你频繁出现在公共空间，但保持着一种有分寸的距离感。你在乎空间的质感——光线、气氛、是否有让人能安静下来的角落——却对空间里的"人"兴趣有限。你使用附近，但不依附于它；你享受城市生活的质感，但不需要被人认识。这是一种现代性的独特产物：对场所有感情，对社群无需求。'},
'Hermit':{name:'主动隔绝者',en:'The Hermit',motto:'不被打扰，是我的自由。',desc:'你对附近的疏离是主动选择的结果，而非疏忽。你清楚地知道这种状态，并认为代价是可接受的——边界感带来安全感，不被打扰是一种自由。你依赖数字基础设施完成几乎所有的生活需求，邻里对你意味着噪音而非资源。你的"附近"是经过剪辑的：剔除了偶然性，也剔除了随之而来的摩擦与温度。'},
'Nomad':{name:'赛博游牧者',en:'The Nomad',motto:'我的附近在5G信号里。',desc:'你的社交半径与地理坐标高度脱钩。你的核心关系网络不依赖于住在附近，而是由兴趣、价值观或数字平台重新组织。物理空间对你来说是居住的容器，而不是归属的来源。这种生活方式在网络时代完全可行，但它也意味着，当网络断线或身体需要帮助的时候，你脚下的土地很难给你托住。'},
'Detached':{name:'清醒疏离者',en:'The Detached',motto:'知道，但选择旁观。',desc:'你对附近的消失有清醒的认识，理解这一现象背后的结构性原因，甚至对它有某种惋惜。但你并没有用行动去抵抗它，因为你同样清楚地看到了投入的成本：时间、精力，以及在高度流动的城市生活中建立关系的脆弱性。你处于一种知道却选择旁观的位置。这不是冷漠，而是一种精于权衡之后的克制。'},
'Drifter':{name:'无感漂流者',en:'The Drifter',motto:'附近？我好像没注意过。',desc:'你对附近没有明显的情感态度，既不投入也不主动逃避。附近只是一个你碰巧住在里面的地方，来了就来了，走了就走了。你不太会注意到那家常去的店是否还开着，也不会想去认识楼道里的邻居。这不是一种选择，更像是一种默认状态——在快节奏的城市生活和高度便利的数字服务中，附近感悄悄消失了，而你也没有特别察觉到它的离开。'},
};

