  q21:{A:{Guardian:2},B:{Guardian:1},C:{Detached:2},D:{Detached:1,Drifter:1},E:{Hermit:1,Drifter:1}},
  q22:{A:{Detached:1},B:{Drifter:1},C:{Nomad:2},D:{Detached:1,Nomad:1},E:{Hermit:1},F:{Guardian:1,Detached:1},G:{}},
  q23:{A:{Guardian:2},B:{Nomad:2},C:{Detached:2},D:{Drifter:1,Hermit:1}},
  q24:{1:{Guardian:1},2:{Guardian:1},3:{Passerby:1,Guardian:1},4:{Guardian:1},5:{Guardian:1},6:{Nomad:1,Passerby:1}},
  q25:{A:{Guardian:2,Builder:1},B:{Guardian:1},C:{Drifter:1},D:{Hermit:1},E:{Hermit:2}},
};

// ===== STATE =====
let qi=0, ans={}, r24={}, scores={}, _tapCount=0, _tapTimer=null;

// ===== INTRO =====
function showIntro(){
  app.innerHTML=`
  <div class="intro">
    <div class="logo" onclick="_secretTap()" style="cursor:default">🏙️</div>
    <h1>你的"附近"人格查询器</h1>
    <div class="sub">NCT — Nearby Connection Type</div>
    <p class="desc">MBTI已经过时了，现在流行测测你在钢筋水泥的森林里，到底是个什么样的"附近生物"。本测试不含任何心理学诊断，纯属娱乐，别拿去相亲或面试！</p>
    <div class="dims">
      <div class="dcard"><div class="dl">类型1</div><div class="dv"><span style="color:var(--accent)">在地守望者</span></div></div>
      <div class="dcard"><div class="dl">类型2</div><div class="dv"><span style="color:var(--green)">社区营造者</span></div></div>
      <div class="dcard"><div class="dl">类型3</div><div class="dv"><span style="color:var(--pink)">氛围栖居者</span></div></div>
      <div class="dcard"><div class="dl">类型4</div><div class="dv"><span style="color:var(--orange)">主动隔绝者</span></div></div>
      <div class="dcard"><div class="dl">类型5</div><div class="dv"><span style="color:#74b9ff">赛博游牧者</span></div></div>
      <div class="dcard"><div class="dl">类型6</div><div class="dv"><span style="color:#a29bfe">清醒疏离者</span></div></div>
      <div class="dcard" style="grid-column:1/-1"><div class="dl">类型7</div><div class="dv"><span style="color:#636e72">无感漂流者</span></div></div>
    </div>
    <button class="start-btn" onclick="goQ(0)">开始测试</button>
  </div>`;
}

// ===== QUESTION PAGE =====
function goQ(i){
  qi=i;
  if(i>=QS.length){calcResult();return;}
  const q=QS[i];
  const total=QS.length;
  const pct=(i/total*100).toFixed(0);

  let body='';
  if(q.type==='single'){
    body=`<div class="opts">${q.opts.map(o=>`<button class="obtn${ans['q'+i]===o.l?' sel':''}" onclick="pickS(${i},'${o.l}',this)"><span class="lt">${o.l}</span><span>${o.t}</span></button>`).join('')}</div>`;
  } else if(q.type==='multi'){
    const sel=ans['q'+i]||[];
    body=`<div class="opts">${q.opts.map(o=>`<button class="obtn ck${sel.includes(o.l)?' on':''}" onclick="pickM(${i},'${o.l}',this)"><span class="lt">✓</span><span>${o.t}</span></button>`).join('')}</div>`;
  } else if(q.type==='rating'){
    body=`<div>${q.hint?`<div class="q-hint">${q.hint}</div>`:''}${q.ratings.map((r,ri)=>`<div class="rrow"><span class="rl">${ri+1}. ${r}</span><div class="rv">${[1,2,3,4,5].map(v=>`<button class="rbtn${r24[ri+1]===v?' on':''}" onclick="pickR(${ri+1},${v},this)">${v}</button>`).join('')}</div></div>`).join('')}</div>`;
  } else if(q.type==='open'){
    body=`<textarea class="tinput" id="openInput" placeholder="${q.placeholder||''}" oninput="ans['q'+${i}]=this.value">${ans['q'+i]||''}</textarea>`;
  }

  const canNext=q.type==='open'||q.type==='multi'||q.type==='rating'||ans['q'+i];

  app.innerHTML=`
  <div class="top-bar">
    <div class="top-row"><span>第${q.stage}阶段 · ${q.stageName}</span><span>${i+1} / ${total}</span></div>
    <div class="prog"><div class="bar" style="width:${pct}%"></div></div>
  </div>
  <div class="q-area">
    <span class="stag ${q.stagClass}">第${q.stage}阶段</span>
    <div class="q-text"><span class="q-num">${i+1}.</span>${q.q}</div>
    ${body}
  </div>
  <div class="nav">
    <button class="nbtn prev" onclick="goQ(${i-1})" ${i===0?'style="visibility:hidden"':''}>← 上一题</button>
    ${i===total-1?`<button class="nbtn submit" onclick="calcResult()">查看结果 →</button>`:`<button class="nbtn next" onclick="tryNext(${i})" ${!canNext?'disabled':''}>下一题 →</button>`}
  </div>`;
}

function pickS(i,v,btn){
  ans['q'+i]=v;
  btn.parentElement.querySelectorAll('.obtn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
  const q=QS[i];
  if(q.filter){
    const f=q.filter(v);
    if(f==='end'){showFilterEnd();return;}
    if(f==='result'){setTimeout(()=>calcResult(),350);return;}
    if(f==='skip16'){setTimeout(()=>goQ(16),350);return;}
  }
  setTimeout(()=>goQ(i+1),350);
}

function pickM(i,v,btn){
  if(!ans['q'+i])ans['q'+i]=[];
  const q=QS[i];
  const maxSel=q.maxSel||999;
  const idx=ans['q'+i].indexOf(v);
  if(idx>=0){ans['q'+i].splice(idx,1);btn.classList.toggle('on',false);}
  else{
    if(ans['q'+i].length>=maxSel){alert('最多只能选'+maxSel+'项');return;}
    ans['q'+i].push(v);btn.classList.toggle('on',true);}
}

function pickR(rid,v,btn){
  r24[rid]=v;
  btn.parentElement.querySelectorAll('.rbtn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
}

function tryNext(i){
  const q=QS[i];
  if(q.type==='single'&&!ans['q'+i])return;
  goQ(i+1);
}

function showFilterEnd(){
  app.innerHTML=`
  <div class="fend show">
    <div class="flogo">👋</div>
    <div class="fmsg">感谢参与！本测试面向在城市定居3个月以上的18-35岁群体。</div>
    <button class="nbtn next" style="margin-top:20px" onclick="resetAll()">重新开始</button>
  </div>`;
}

// ===== CALC =====
function calcResult(){
  const typeKeys=Object.keys(TYPES);
  scores={};typeKeys.forEach(k=>scores[k]=0);
  const add=o=>{if(!o)return;for(const k in o)if(scores[k]!==undefined)scores[k]+=o[k]};
  for(let i=0;i<QS.length;i++){
    const q=QS[i],key='q'+i;
    if(q.type==='single'){
      if(ans[key]&&SC[key]&&SC[key][ans[key]])add(SC[key][ans[key]]);
    } else if(q.type==='multi'){
      if(ans[key]&&SC[key])ans[key].forEach(v=>{if(SC[key][v])add(SC[key][v])});
    } else if(q.type==='rating'){
      if(SC.q24)for(const rid in r24){const b=SC.q24[rid];if(b){const f=r24[rid]/3;for(const k in b)if(scores[k]!==undefined)scores[k]+=Math.round(b[k]*f*10)/10}}
    }
  }
  let maxScore=-1,code='Drifter';
  typeKeys.forEach(k=>{if(scores[k]>maxScore){maxScore=scores[k];code=k;}});
  showResult(code);
}

// ===== RESULT =====
function showResult(code){
  // Save response data
  saveResponse(code);
  const t=TYPES[code]||TYPES['Drifter'];
  // Build score bar
  const typeKeys=Object.keys(TYPES);
  const maxS=Math.max(1,...typeKeys.map(k=>scores[k]));
  const scoreBars=typeKeys.map(k=>{
    const pct=Math.round(scores[k]/maxS*100);
    const isWin=k===code;
    const colors={Guardian:'#6c5ce7',Builder:'#00b894',Passerby:'#e84393',Hermit:'#e17055',Nomad:'#74b9ff',Detached:'#a29bfe',Drifter:'#636e72'};
    return `<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
      <span style="width:70px;font-size:12px;font-weight:${isWin?'800':'500'};color:${isWin?colors[k]:'#636e72'};text-align:right">${TYPES[k].name}</span>
      <div style="flex:1;height:18px;background:rgba(0,0,0,.04);border-radius:6px;overflow:hidden">
        <div style="width:${pct}%;height:100%;background:${colors[k]};opacity:${isWin?'.8':'.3'};border-radius:6px;transition:width .5s"></div>
      </div>
      <span style="font-size:12px;font-weight:${isWin?'800':'500'};color:${isWin?colors[k]:'#636e72'};width:30px">${scores[k]}</span>
    </div>`;
  }).join('');
  app.innerHTML=`
  <div class="result show">
    <div class="illust">${svgIllust(code)}</div>
    <div class="rcode" style="font-size:22px;letter-spacing:2px">${t.name}</div>
    <div style="font-size:14px;color:var(--accent);margin-bottom:4px">${t.en}</div>
    <div class="rmotto">${t.motto}</div>
    <div class="rdesc">${t.desc}</div>
    <div style="width:100%;max-width:420px;margin-bottom:28px;animation:fadeUp .8s ease .25s both">
      <div style="font-size:13px;font-weight:700;margin-bottom:10px;color:#2d3436">各类型得分</div>
      ${scoreBars}
    </div>
    <button class="rbtn2" onclick="resetAll()">再测一次</button>
  </div>`;
}

function resetAll(){
  scores={};ans={};r24={};showIntro();
}

// ===== SECRET ADMIN ACCESS =====
function _secretTap(){
  _tapCount++;
  clearTimeout(_tapTimer);
  _tapTimer=setTimeout(()=>{_tapCount=0;},1500);
  if(_tapCount>=5){_tapCount=0;showAdmin();}
}

// ===== DATA STORAGE =====
const STORAGE_KEY='nct_responses';
function getResponses(){
  try{return JSON.parse(localStorage.getItem(STORAGE_KEY))||[];}catch(e){return[];}
}
function saveResponse(code){
  const responses=getResponses();
  const record={
    id:Date.now(),
    time:new Date().toLocaleString('zh-CN'),
    code:code,
    scores:{...scores},
  };
  // Save each question answer
  for(let i=0;i<QS.length;i++){
    const key='q'+i;
    if(ans[key]!==undefined) record[key]=Array.isArray(ans[key])?ans[key].join(','):(ans[key]||'');
    else record[key]='';
  }
  // Save rating details
  record.ratings={...r24};
  // Save open answer
  const openEl=document.getElementById('openInput');
  if(openEl) record.q25_open=openEl.value;
  responses.push(record);
  try{localStorage.setItem(STORAGE_KEY,JSON.stringify(responses));}catch(e){}
}

// ===== CSV EXPORT =====
function exportCSV(){
  const data=getResponses();
  if(!data.length){alert('暂无数据');return;}
  // Build header
  const headers=['序号','时间','人格类型','Guardian','Builder','Passerby','Hermit','Nomad','Detached','Drifter'];
  for(let i=0;i<QS.length;i++) headers.push('Q'+(i+1));
  headers.push('评分1','评分2','评分3','评分4','评分5','评分6');
  // Build rows
  const rows=data.map((r,idx)=>{
    const row=[idx+1,r.time,r.code,
      r.scores.Guardian||0,r.scores.Builder||0,r.scores.Passerby||0,r.scores.Hermit||0,r.scores.Nomad||0,r.scores.Detached||0,r.scores.Drifter||0];
    for(let i=0;i<QS.length;i++) row.push(r['q'+i]||'');
    const rt=r.ratings||{};
    row.push(rt[1]||'',rt[2]||'',rt[3]||'',rt[4]||'',rt[5]||'',rt[6]||'');
    return row;
  });
  // Generate CSV with BOM for Excel
  let csv='\uFEFF';
  csv+=headers.map(h=>'"'+h+'"').join(',')+'\n';
  rows.forEach(row=>{csv+=row.map(v=>'"'+String(v).replace(/"/g,'""')+'"').join(',')+'\n';});
  // Download
  const blob=new Blob([csv],{type:'text/csv;charset=utf-8'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;
  a.download='NCT测试数据_'+new Date().toLocaleDateString('zh-CN').replace(/\//g,'-')+'.csv';
  a.click();
  URL.revokeObjectURL(url);
}

// ===== JSON EXPORT =====
function exportJSON(){
  const data=getResponses();
  if(!data.length){alert('暂无数据');return;}
  const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;
  a.download='NCT测试数据_'+new Date().toLocaleDateString('zh-CN').replace(/\//g,'-')+'.json';
  a.click();
  URL.revokeObjectURL(url);
}

// ===== ADMIN DASHBOARD =====
function showAdmin(){
  const data=getResponses();
  const total=data.length;
  // Type distribution
  const typeCounts={};
  Object.keys(TYPES).forEach(k=>typeCounts[k]=0);
  data.forEach(r=>{if(typeCounts[r.code]!==undefined)typeCounts[r.code]++;});
  // Dimension averages
  const avg={E:0,I:0,S:0,N:0,O:0,H:0,C:0,D:0};
  if(total){data.forEach(r=>{for(const k in avg)avg[k]+=r.scores[k]||0;});for(const k in avg)avg[k]=(avg[k]/total).toFixed(1);}
  // Type distribution bar chart
  const maxCount=Math.max(1,...Object.values(typeCounts));
  const typeBarW=16,gap=6,chartW=Object.keys(typeCounts).length*(typeBarW+gap);
  const chartH=120;
  const typeBars=Object.entries(typeCounts).map(([k,v],i)=>{
    const x=i*(typeBarW+gap)+8;
    const bh=Math.max(1,v/maxCount*(chartH-20));
    const y=chartH-bh-2;
    const fill=v>0?'#6c5ce7':'rgba(0,0,0,.06)';
    return `<rect x="${x}" y="${y}" width="${typeBarW}" height="${bh}" rx="2" fill="${fill}" opacity="${v?0.7:0.3}"/><text x="${x+typeBarW/2}" y="${y-3}" text-anchor="middle" font-size="7" fill="${v?'#2d3436':'#b2bec3'}">${v||''}</text><text x="${x+typeBarW/2}" y="${chartH+10}" text-anchor="middle" font-size="6" fill="#636e72">${k}</text>`;
  }).join('');
  // Dimension comparison
  // Dimension comparison (7 types)
  const typeColors={Guardian:'#6c5ce7',Builder:'#00b894',Passerby:'#e84393',Hermit:'#e17055',Nomad:'#74b9ff',Detached:'#a29bfe',Drifter:'#636e72'};
  const dimPairs=Object.keys(TYPES).map(k=>({n:TYPES[k].name,c:typeColors[k],k:k}));
  const dimChartW=280,dimChartH=100;
  const dimBars=dimPairs.map((p,i)=>{
    const y=i*14+8;
    const w=Math.max(2,(avg[p.k]||0)/(maxAvg+0.01)*(dimChartW-60));
    return `<rect x="0" y="${y}" width="${w}" height="10" rx="3" fill="${p.c}" opacity=".7"/><text x="${w+4}" y="${y+8}" font-size="7" fill="#636e72">${(avg[p.k]||0).toFixed(1)}</text><text x="${dimChartW-2}" y="${y+8}" font-size="7" fill="#2d3436" text-anchor="end" font-weight="600">${p.n}</text>`;
  }).join('');

  // ===== Per-question option distribution =====
  const barColors=['#6c5ce7','#00b894','#e84393','#e17055','#a29bfe','#55efc4','#fd79a8','#fab1a0'];
  let qStatsHTML='';
  QS.forEach((q,qi)=>{
    const key='q'+qi;
    // Count respondents for this question
    const respondents=data.filter(r=>r[key]!==undefined&&r[key]!=='');
    const rTotal=respondents.length;
    let body='';
    const typeLabel=q.type==='single'?'单选':q.type==='multi'?'多选':q.type==='rating'?'量表':q.type==='open'?'开放':'--';
    body+=`<div class="qs-head"><span class="qs-num">Q${qi+1}</span><span class="qs-type">${typeLabel}</span></div>`;
    body+=`<div class="qs-text">${q.q}</div>`;
    if(q.type==='single'&&q.opts){
      q.opts.forEach((o,oi)=>{
        const cnt=respondents.filter(r=>r[key]===o.l).length;
        const pct=rTotal?Math.round(cnt/rTotal*100):0;
        const col=barColors[oi%barColors.length];
        body+=`<div class="qs-opt">${o.l}. ${o.t}</div>`;
        body+=`<div class="qs-row"><span class="qs-lbl">${o.l}</span><div class="qs-bar-wrap"><div class="qs-bar" style="width:${pct}%;background:${col};opacity:.7"></div><span class="qs-bar-text">${cnt}人 (${pct}%)</span></div></div>`;
      });
    } else if(q.type==='multi'&&q.opts){
      q.opts.forEach((o,oi)=>{
        const cnt=respondents.filter(r=>{const a=r[key];return a&&a.split(',').includes(o.l)}).length;
        const pct=rTotal?Math.round(cnt/rTotal*100):0;
        const col=barColors[oi%barColors.length];
        body+=`<div class="qs-opt">${o.l}. ${o.t}</div>`;
        body+=`<div class="qs-row"><span class="qs-lbl">${o.l}</span><div class="qs-bar-wrap"><div class="qs-bar" style="width:${pct}%;background:${col};opacity:.7"></div><span class="qs-bar-text">${cnt}人 (${pct}%)</span></div></div>`;
      });
    } else if(q.type==='rating'&&q.ratings){
      q.ratings.forEach((r,ri)=>{
        const rid=ri+1;
        const vals=respondents.filter(r=>r.ratings&&r.ratings[rid]).map(r=>r.ratings[rid]);
        const avg2=vals.length?(vals.reduce((a,b)=>a+b,0)/vals.length).toFixed(1):'--';
        body+=`<div class="qs-opt">${rid}. ${r}</div>`;
        body+=`<div class="qs-row"><span class="qs-lbl">${rid}</span><div class="qs-bar-wrap"><div class="qs-bar" style="width:${avg2!=='--'?avg2/5*100:0}%;background:${barColors[ri%barColors.length]};opacity:.7"></div><span class="qs-bar-text">均分 ${avg2} (${vals.length}人)</span></div></div>`;
      });
    } else if(q.type==='open'){
      const cnt=respondents.filter(r=>r[key]).length;
      body+=`<div class="qs-avg">收到 ${cnt} 条回答（详见CSV导出）</div>`;
    }
    qStatsHTML+=`<div class="q-stat">${body}</div>`;
  });

  // Data table
  const tableRows=data.slice(-50).reverse().map((r,idx)=>{
    const i=data.length-idx;
    return `<tr><td>${i}</td><td>${r.time}</td><td><b>${r.code}</b></td><td>${r.scores.E}</td><td>${r.scores.I}</td><td>${r.scores.S}</td><td>${r.scores.N}</td><td>${r.scores.O}</td><td>${r.scores.H}</td><td>${r.scores.C}</td><td>${r.scores.D}</td>${QS.map((_,qi)=>`<td>${r['q'+qi]||''}</td>`).join('')}</tr>`;
  }).join('');

  app.innerHTML=`
  <div class="admin">
    <button class="admin-btn" style="position:static;margin-bottom:16px" onclick="showIntro()">← 返回首页</button>
    <h2>📊 数据管理面板</h2>
    <p class="sub">所有数据保存在浏览器本地，清除浏览器数据会丢失。请定期导出备份。</p>
    <div class="stat-grid">
      <div class="stat-card"><div class="sl">总参与人数</div><div class="sv" style="color:#6c5ce7">${total}</div></div>
      <div class="stat-card"><div class="sl">最多的人格</div><div class="sv" style="color:#00b894">${Object.entries(typeCounts).sort((a,b)=>b[1]-a[1])[0][0]}</div></div>
      <div class="stat-card"><div class="sl">守望者占比</div><div class="sv" style="color:#e84393">${total?Math.round(data.filter(r=>r.code==='Guardian').length/total*100):0}%</div></div>
      <div class="stat-card"><div class="sl">游牧者占比</div><div class="sv" style="color:#e17055">${total?Math.round(data.filter(r=>r.code==='Nomad').length/total*100):0}%</div></div>
    </div>
    <div class="chart-row">
      <div class="chart-box"><h3>7种人格分布</h3><svg viewBox="0 0 ${chartW+20} ${chartH+18}" xmlns="http://www.w3.org/2000/svg">${typeBars}</svg></div>
      <div class="chart-box"><h3>类型平均分对比</h3><svg viewBox="0 0 ${dimChartW+10} ${dimChartH}" xmlns="http://www.w3.org/2000/svg">${dimBars}</svg></div>
    </div>
    <div class="exp-row">
      <button class="exp-btn" onclick="exportCSV()">📥 导出 CSV（Excel/SPSS）</button>
      <button class="exp-btn" onclick="exportJSON()">📥 导出 JSON</button>
      <button class="exp-btn" onclick="if(confirm('确定清空所有数据？此操作不可恢复！')){localStorage.removeItem('nct_responses');showAdmin();}">🗑️ 清空数据</button>
    </div>
    <div class="section-title">逐题选项分布</div>
    ${qStatsHTML}
    <div class="section-title">原始数据表（最近50条）</div>
    <div class="tbl-wrap">
      <table>
        <tr><th>#</th><th>时间</th><th>类型</th><th>Gu</th><th>Bu</th><th>Pa</th><th>He</th><th>No</th><th>De</th><th>Dr</th>${QS.map((_,i)=>'<th>Q'+(i+1)+'</th>').join('')}</tr>
        ${tableRows}
      </table>
    </div>
  </div>`;
}

showIntro();

</script>
</body>
</html>
